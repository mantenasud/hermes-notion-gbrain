# Copy this file to .env and fill in your values
# Never commit .env to git

# Notion Integration Token
# Get from: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# Notion Database ID
# Get from your database URL: notion.so/workspace/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path to GBrain binary (gbrain_enrichment.py uses this)
GBRAIN_PATH=/home/ubuntu/.bun/bin/gbrain

# OpenAI key is read automatically from GBrain config
# No need to set it here unless GBrain is not installed
# OPENAI_API_KEY=sk-...
